:106,"column":2},"source":"components/MainView/mainView.jsx","original":{"line":4,"column":30}},{"name":"Component","generated":{"line":106,"column":17},"source":"components/MainView/mainView.jsx","original":{"line":4,"column":36}},{"name":"MainView","generated":{"line":109,"column":15},"source":"components/MainView/mainView.jsx","original":{"line":41,"column":15}}],"sources":{"components/MainView/mainView.jsx":"import React from 'react';\r\nimport axios from 'axios';\r\n\r\nexport class MainView extends React.Component {\r\n    constructor() {\r\n        super();\r\n        this.state = {};\r\n    }\r\n    componentDidMount() {\r\n        axios.get('https://myflixdbs-z.herokuapp.com/movies').then(res => {\r\n            this.setState({ movies: res.data });\r\n        })\r\n            .catch(function (error) {\r\n                console.log(error);\r\n            });\r\n    }\r\n\r\n    onMovieClick(movie) {\r\n        this.setState({ selectedMovie: movie })\r\n    }\r\n\r\n    render() {\r\n        const { movies, selectedMovie, Button } = this.state;\r\n        if (!movies) return <div className=\"main-view\" />;\r\n\r\n        return (\r\n            <div className=\"main-view\">\r\n                {selectedMovie\r\n                    ? <MovieView movie={selectedMovie} />\r\n                    : movies.map(movie => (\r\n                        <MovieCard key={movie._id} movie={movie} onClick={movie => this.onMovieClick(movie)} />\r\n                            ? <MovieView BackButton={Button} />\r\n                            : <Return onClick={Button => this.onButtonClick()} />\r\n                    ))\r\n                }\r\n            </div>\r\n        );\r\n    }\r\n}\r\n\r\nexport default MainView\r\n"},"lineCount":null}},"error":null,"hash":"ddcb65e73daf8ba7982c7878be3b937a","cacheData":{"env":{}}}